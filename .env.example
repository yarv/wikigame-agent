# Copy to .env and fill in.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model used by inspect_ai. Format: provider/model-id.
INSPECT_EVAL_MODEL=openai/gpt-4o-mini

# Wikipedia API etiquette: identify yourself.
# Wikipedia silently rate-limits clients with a missing/default UA, which is
# what produced the JSONDecodeErrors in the original notebook.
WIKIGAME_USER_AGENT=wikigame-agent/0.1 (yariv@barsheshat.com)
